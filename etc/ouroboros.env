# Ouroboros runtime configuration
# This file is read dynamically; changes take effect within 30 seconds

# Primary model for main reasoning
OUROBOROS_MODEL=gemini-2.5-pro

# Fallback models (comma-separated, tried in order)
OUROBOROS_MODEL_FALLBACK_LIST=gemini-2.5-flash,qwen3.5-plus

# Code-specific model (for code generation/review)
OUROBOROS_MODEL_CODE=qwen3-coder-next

# Light model for quick tasks
OUROBOROS_MODEL_LIGHT=glm-5

# API configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=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
